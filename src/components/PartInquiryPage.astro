---
import BaseLayout from "../layouts/BaseLayout.astro";

interface LinkItem {
  title: string;
  desc: string;
  href: string;
}

interface TextItem {
  title: string;
  desc: string;
}

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  pageTitle: string;
  pageDescription: string;
  keywords: string[];
  canonical: string;
  ogImage: string;
  jsonLd: object[];
  systemLabel: string;
  heroTitle: string;
  heroLead: string;
  primaryCtaLabel: string;
  painPointsHeading: string;
  painPoints: TextItem[];
  matchingInputs: string[];
  processSteps: TextItem[];
  whyWorkWithUsHeading: string;
  whyWorkWithUs: TextItem[];
  faq: FaqItem[];
  relatedPathsHeading?: string;
  relatedPaths: LinkItem[];
}

const {
  pageTitle,
  pageDescription,
  keywords,
  canonical,
  ogImage,
  jsonLd,
  systemLabel,
  heroTitle,
  heroLead,
  primaryCtaLabel,
  painPointsHeading,
  painPoints,
  matchingInputs,
  processSteps,
  whyWorkWithUsHeading,
  whyWorkWithUs,
  faq,
  relatedPathsHeading = "Need to start from a truck brand instead?",
  relatedPaths,
} = Astro.props;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={keywords}
  canonical={canonical}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <style>@import "../styles/product-detail.css";</style>

  <section class="hero">
    <div class="heroBg" style={`background-image:url('${ogImage}')`} aria-hidden="true"></div>
    <div class="overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="heroInner">
        <div>
          <p class="eyebrow">CertiRun / Parts Inquiry</p>
          <h1>{heroTitle}</h1>
          <p class="heroLead">{heroLead}</p>
          <div class="heroActions">
            <a class="btn primary" href="/contact">{primaryCtaLabel}</a>
          </div>
        </div>

        <aside class="heroPanel">
          <b>What to send for a faster reply</b>
          <div class="heroList">
            {matchingInputs.slice(0, 5).map((item) => (
              <div class="heroListItem">
                <span class="heroDot"></span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">{painPointsHeading}</h2>
      <div class="grid3">
        {painPoints.map((item) => (
          <div class="card">
            <b>{item.title}</b>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="ctaBlock">
        <div class="left">
          <b>Not all supported parts are listed here</b>
          <p>
            If your request is more specific than the categories on this page, send the references you already have and
            we will check the workable scope for {systemLabel.toLowerCase()}.
          </p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a class="btn primary" href="/contact">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">What happens after you send the inquiry</h2>
      <div class="grid2">
        {processSteps.map((step) => (
          <div class="card">
            <b>{step.title}</b>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">{whyWorkWithUsHeading}</h2>
      <div class="grid3">
        {whyWorkWithUs.map((item) => (
          <div class="card">
            <b>{item.title}</b>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">FAQ</h2>
      <div class="faq">
        {faq.map((item) => (
          <div class="faqItem">
            <strong>{item.q}</strong>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">{relatedPathsHeading}</h2>
      <div class="grid3">
        {relatedPaths.map((item) => (
          <div class="card">
            <b><a href={item.href}>{item.title}</a></b>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="ctaBlock">
        <div class="left">
          <b>Ready to send your {systemLabel.toLowerCase()} inquiry?</b>
          <p>
            Send the references you already have. We will review the scope first, then move into matching, quotation,
            inspection, and shipment follow-up.
          </p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a class="btn primary" href="/contact">{primaryCtaLabel}</a>
          <a class="btn" href="/contact">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
