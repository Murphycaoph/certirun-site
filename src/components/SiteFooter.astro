---
const year = new Date().getFullYear();

const footerLinks = [
  { href: "/capabilities", label: "Services" },
  { href: "/industries", label: "Industries" },
  { href: "/how-it-works", label: "How It Works" },
  { href: "/cases", label: "Cases" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<div class="footerWrap">
  <div class="container wide">
    <footer class="footerShell">
      <div class="footerMeta">
        <img src="/images/brand/certirunlogo.webp" alt="CertiRun logo" class="footerLogoImage" />
        <p>
          Operational verification foundations for sourcing, execution, and cross-border
          coordination.
        </p>
        <div class="footerNote">(c) {year} CertiRun</div>
      </div>

      <nav class="footerNav" aria-label="Footer navigation">
        {footerLinks.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </footer>
  </div>
</div>
