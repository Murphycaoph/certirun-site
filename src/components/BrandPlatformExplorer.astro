---
type SupportGroup = {
  title: string;
  items: string[];
};

type Platform = {
  id: string;
  name: string;
  family?: string;
  image: string;
  imageAlt: string;
  imageStyle?: string;
  supportGroups: SupportGroup[];
  detailTitle?: string;
  whatsappLabel?: string;
};

type Assembly = {
  id: string;
  label: string;
  helper?: string;
  platforms: Platform[];
};

interface Props {
  id?: string;
  title: string;
  description: string;
  eyebrow?: string;
  assemblies: Assembly[];
  whatsappHref?: string;
  fallbackText?: string;
  fallbackCtaLabel?: string;
}

const {
  id = "brand-platform-explorer",
  title,
  description,
  eyebrow = "Brand Platform Explorer",
  assemblies,
  whatsappHref = "https://wa.me/8615633022618?text=Hello%20CertiRun%2C%20I%20want%20to%20discuss%20truck%20parts%20sourcing.",
  fallbackText,
  fallbackCtaLabel = "Chat on WhatsApp",
} = Astro.props as Props;

const firstAssembly = assemblies[0];
const firstPlatform = firstAssembly?.platforms[0];
---

<section class="explorerSection" id={id}>
  <div class="container">
    <div class="explorerIntro">
      <p class="explorerEyebrow">{eyebrow}</p>
      <h2 class="explorerTitle">{title}</h2>
      {description && <p class="explorerDesc">{description}</p>}
    </div>

    <div class="explorerShell">
      <div class="assemblyRail" role="tablist" aria-label="Assembly filters">
        {assemblies.map((assembly, index) => (
          <button
            class={`assemblyPill ${index === 0 ? "isActive" : ""}`}
            type="button"
            data-assembly-id={assembly.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            <span>{assembly.label}</span>
            {assembly.helper && <small>{assembly.helper}</small>}
          </button>
        ))}
      </div>

      <div class="explorerBody">
        <div class="platformColumn">
          <div class="explorerMeta">
            <div>
              <p class="explorerMetaLabel">Platform</p>
              <strong class="explorerMetaTitle" data-assembly-title>{firstAssembly?.label}</strong>
            </div>
            <span class="explorerMetaCount" data-platform-count>{firstAssembly?.platforms.length ?? 0} options</span>
          </div>

          <div class="platformGrid" data-platform-list>
            {firstAssembly?.platforms.map((platform, index) => (
              <button
                class={`platformCard ${index === 0 ? "isActive" : ""}`}
                type="button"
                data-platform-id={platform.id}
              >
                <img src={platform.image} alt={platform.imageAlt} loading="lazy" style={platform.imageStyle} />
                <div class="platformCopy">
                  <strong>{platform.name}</strong>
                  {platform.family && <span class="platformFamily">{platform.family}</span>}
                  <span class="platformLink">Check support scope</span>
                </div>
              </button>
            ))}
          </div>
        </div>

        {firstPlatform && (
          <aside class="detailPanel" data-detail-panel>
            <p class="detailPath">{firstAssembly.label} / {firstPlatform.name}</p>
            <p class="detailKicker">Parts support</p>
            <h3 class="detailTitle">
              {firstPlatform.detailTitle ?? `Supported parts for ${firstPlatform.name}`}
            </h3>

            <div class="detailGroups">
              {firstPlatform.supportGroups.map((group) => (
                <section class="detailGroup">
                  <strong>{group.title}</strong>
                  <div class="detailTags">
                    {group.items.map((item) => (
                      <span class="detailTag">{item}</span>
                    ))}
                  </div>
                </section>
              ))}
            </div>

            <div class="detailCta">
              <a class="btn primary" href={whatsappHref} target="_blank" rel="noopener noreferrer">
                {firstPlatform.whatsappLabel ?? "Ask about this platform on WhatsApp"}
              </a>
            </div>
          </aside>
        )}
      </div>
      {fallbackText && (
        <div class="explorerFallback">
          <p>{fallbackText}</p>
          <a class="btn primary" href={whatsappHref} target="_blank" rel="noopener noreferrer">
            {fallbackCtaLabel}
          </a>
        </div>
      )}
    </div>
  </div>
</section>

<script define:vars={{ explorerId: id, explorerAssemblies: assemblies, whatsappHref }}>
  const root = document.getElementById(explorerId);

  if (root) {
    const assemblyButtons = Array.from(root.querySelectorAll("[data-assembly-id]"));
    const platformList = root.querySelector("[data-platform-list]");
    const detailPanel = root.querySelector("[data-detail-panel]");
    const assemblyTitle = root.querySelector("[data-assembly-title]");
    const platformCount = root.querySelector("[data-platform-count]");

    let activeAssembly = explorerAssemblies[0];
    let activePlatform = activeAssembly?.platforms?.[0];

    const renderPlatformList = (assembly) => {
      if (!platformList) return;

      platformList.innerHTML = "";

      assembly.platforms.forEach((platform, index) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = `platformCard${index === 0 ? " isActive" : ""}`;
        button.dataset.platformId = platform.id;
        button.innerHTML = `
          <img src="${platform.image}" alt="${platform.imageAlt}" loading="lazy" style="${platform.imageStyle ?? ""}" />
          <div class="platformCopy">
            <strong>${platform.name}</strong>
            ${platform.family ? `<span class="platformFamily">${platform.family}</span>` : ""}
            <span class="platformLink">Check support scope</span>
          </div>
        `;

        button.addEventListener("click", () => {
          activePlatform = platform;
          updatePlatformState();
          renderDetail();
        });

        platformList.appendChild(button);
      });
    };

    const updatePlatformState = () => {
      const platformButtons = Array.from(root.querySelectorAll("[data-platform-id]"));
      platformButtons.forEach((button) => {
        button.classList.toggle("isActive", button.dataset.platformId === activePlatform.id);
      });
    };

    const renderDetail = () => {
      if (!detailPanel || !activeAssembly || !activePlatform) return;

      const groupsMarkup = activePlatform.supportGroups
        .map((group) => {
          const tags = group.items
            .map((item) => `<span class="detailTag">${item}</span>`)
            .join("");

          return `
            <section class="detailGroup">
              <strong>${group.title}</strong>
              <div class="detailTags">${tags}</div>
            </section>
          `;
        })
        .join("");

      detailPanel.innerHTML = `
        <p class="detailPath">${activeAssembly.label} / ${activePlatform.name}</p>
        <p class="detailKicker">Parts support</p>
        <h3 class="detailTitle">${activePlatform.detailTitle ?? `Supported parts for ${activePlatform.name}`}</h3>
        <div class="detailGroups">${groupsMarkup}</div>
        <div class="detailCta">
          <a class="btn primary" href="${whatsappHref}" target="_blank" rel="noopener noreferrer">
            ${activePlatform.whatsappLabel ?? "Ask about this platform on WhatsApp"}
          </a>
        </div>
      `;
    };

    const setAssembly = (assemblyId) => {
      const nextAssembly = explorerAssemblies.find((assembly) => assembly.id === assemblyId);
      if (!nextAssembly) return;

      activeAssembly = nextAssembly;
      activePlatform = nextAssembly.platforms[0];

      assemblyButtons.forEach((button) => {
        const isActive = button.dataset.assemblyId === assemblyId;
        button.classList.toggle("isActive", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      if (assemblyTitle) assemblyTitle.textContent = nextAssembly.label;
      if (platformCount) platformCount.textContent = `${nextAssembly.platforms.length} options`;

      renderPlatformList(nextAssembly);
      renderDetail();
    };

    assemblyButtons.forEach((button) => {
      button.addEventListener("click", () => setAssembly(button.dataset.assemblyId));
    });

    setAssembly(activeAssembly.id);
  }
</script>

<style is:global>
  .explorerSection{ padding:30px 0; }
  .explorerIntro{ margin-bottom:18px; }
  .explorerEyebrow{
    margin:0 0 8px;
    font-size:12px;
    font-weight:900;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:#5c6c87;
  }
  .explorerTitle{
    margin:0 0 10px;
    font-size:30px;
    line-height:1.15;
    color:#172434;
  }
  .explorerDesc{
    margin:0;
    max-width:860px;
    color:#5f6d86;
    line-height:1.8;
  }
  .explorerShell{
    border:1px solid rgba(29,42,54,.10);
    border-radius:28px;
    background:linear-gradient(180deg, rgba(255,255,255,.94), rgba(246,249,252,.98));
    box-shadow:0 22px 60px rgba(18,30,48,.08);
    overflow:hidden;
  }
  .assemblyRail{
    display:flex;
    gap:12px;
    padding:18px;
    overflow-x:auto;
    border-bottom:1px solid rgba(29,42,54,.08);
    background:linear-gradient(180deg, rgba(245,248,252,.95), rgba(238,243,247,.95));
  }
  .assemblyPill{
    min-width:150px;
    min-height:58px;
    padding:14px 16px;
    border-radius:18px;
    border:1px solid rgba(29,42,54,.12);
    background:#fff;
    text-align:left;
    cursor:pointer;
    transition:all .18s ease;
    box-shadow:0 10px 24px rgba(17,26,51,.04);
    display:flex;
    align-items:center;
  }
  .assemblyPill span{
    display:block;
    color:#172434;
    font-weight:800;
  }
  .assemblyPill small{
    display:block;
    margin-top:5px;
    color:#6b7b95;
    line-height:1.5;
  }
  .assemblyPill.isActive{
    border-color:rgba(57,87,233,.35);
    background:linear-gradient(180deg, rgba(240,244,255,.98), rgba(229,236,255,.94));
    box-shadow:0 16px 34px rgba(57,87,233,.12);
  }
  .explorerBody{
    display:grid;
    grid-template-columns:minmax(0, 1.15fr) minmax(280px, .85fr);
  }
  .platformColumn{
    padding:18px;
    border-right:1px solid rgba(29,42,54,.08);
  }
  .explorerMeta{
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:12px;
    margin-bottom:14px;
  }
  .explorerMetaLabel{
    margin:0 0 4px;
    color:#70809b;
    font-size:12px;
    font-weight:900;
    letter-spacing:.12em;
    text-transform:uppercase;
  }
  .explorerMetaTitle{
    color:#172434;
    font-size:20px;
  }
  .explorerMetaCount{
    color:#6b7b95;
    font-weight:700;
    white-space:nowrap;
  }
  .platformGrid{
    display:grid;
    grid-template-columns:1fr;
    gap:10px;
  }
  .platformCard{
    position:relative;
    display:block;
    min-height:116px;
    padding:12px 14px;
    border-radius:20px;
    border:1px solid rgba(29,42,54,.10);
    background:#fff;
    cursor:pointer;
    text-align:left;
    transition:all .18s ease;
    box-shadow:0 14px 30px rgba(18,30,48,.05);
    overflow:hidden;
  }
  .platformCard::after{
    content:"";
    position:absolute;
    inset:0;
    background:linear-gradient(90deg, rgba(255,255,255,1) 0%, rgba(255,255,255,.98) 34%, rgba(255,255,255,.82) 56%, rgba(255,255,255,.42) 74%, rgba(255,255,255,.08) 100%);
    pointer-events:none;
    z-index:1;
  }
  .platformCard img{
    position:absolute;
    top:0;
    right:-20%;
    width:78%;
    height:100%;
    object-fit:cover;
    object-position:center;
    display:block;
    z-index:0;
  }
  .platformCard strong{
    display:block;
    color:#172434;
    font-size:15px;
    line-height:1.22;
  }
  .platformFamily{
    display:inline-block;
    margin-top:4px;
    color:#58698a;
    font-size:12px;
    font-weight:700;
  }
  .platformCopy{
    position:relative;
    z-index:2;
    max-width:48%;
    min-height:92px;
    display:flex;
    flex-direction:column;
    justify-content:center;
  }
  .platformLink{
    display:inline-flex;
    margin-top:8px;
    color:#1d3fd3;
    font-weight:800;
    font-size:12px;
  }
  .platformCard.isActive{
    border-color:rgba(57,87,233,.36);
    box-shadow:0 18px 36px rgba(57,87,233,.12);
    background:linear-gradient(180deg, rgba(244,247,255,.98), rgba(233,239,255,.92));
  }
  .detailPanel{
    padding:22px 20px;
    background:linear-gradient(180deg, rgba(241,246,252,.98), rgba(233,239,247,.98));
  }
  .detailPath,
  .detailKicker{
    margin:0;
    font-size:12px;
    font-weight:900;
    letter-spacing:.12em;
    text-transform:uppercase;
  }
  .detailPath{ color:#667892; }
  .detailKicker{
    margin-top:10px;
    color:#2d4fd4;
  }
  .detailTitle{
    margin:10px 0 10px;
    color:#172434;
    font-size:25px;
    line-height:1.08;
    letter-spacing:-.04em;
  }
  .detailGroups{
    display:grid;
    gap:12px;
    margin-top:12px;
  }
  .detailGroup{
    padding:12px;
    border-radius:16px;
    background:rgba(255,255,255,.92);
    border:1px solid rgba(29,42,54,.10);
    box-shadow:0 12px 24px rgba(18,30,48,.04);
  }
  .detailGroup strong{
    display:block;
    margin-bottom:8px;
    color:#172434;
    font-size:14px;
  }
  .detailTags{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
  }
  .detailTag{
    display:inline-flex;
    align-items:center;
    min-height:30px;
    padding:6px 10px;
    border-radius:999px;
    background:#eaf0ff;
    color:#2943b6;
    font-size:12px;
    font-weight:700;
  }
  .detailCta{
    margin-top:16px;
    padding-top:16px;
    border-top:1px solid rgba(29,42,54,.08);
  }

  .explorerFallback{
    margin:0;
    padding:16px 18px;
    border-top:1px solid rgba(29,42,54,.08);
    background:linear-gradient(180deg, rgba(248,251,255,.96), rgba(238,244,251,.98));
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:14px;
  }

  .explorerFallback p{
    margin:0;
    color:#314155;
    line-height:1.7;
  }
  .explorerFallback .btn{
    white-space:nowrap;
    flex:0 0 auto;
  }
  .detailCta .btn{ width:100%; }

  @media (max-width: 1080px){
    .explorerBody{ grid-template-columns:1fr; }
    .platformColumn{
      border-right:none;
      border-bottom:1px solid rgba(29,42,54,.08);
    }
  }
  @media (max-width: 720px){
    .assemblyRail{ padding:14px; }
    .assemblyPill{ min-width:136px; }
    .platformGrid{ grid-template-columns:1fr; }
    .platformCard{
      min-height:104px;
      padding:10px 12px;
    }
    .platformCard img{
      right:-16%;
      width:76%;
      height:100%;
    }
    .detailTitle{ font-size:28px; }
    .explorerFallback{
      flex-direction:column;
      align-items:flex-start;
    }
  }
</style>
