---
import Container from "./Container.astro";

const nav = [
  { href: "/capabilities", label: "Services" },
  {
    href: "/industries",
    label: "Industries",
    children: [
      {
        href: "/industries/electronics-electronic-components/",
        label: "Electronics & Electronic Components",
      },
      {
        href: "/industries/machinery-industrial-equipment/",
        label: "Machinery & Industrial Equipment",
      },
      { href: "/industries/hardware-products/", label: "Hardware Products" },
      {
        href: "/industries/vehicle-parts/",
        label: "Commercial & Passenger Vehicle Parts",
      },
      {
        href: "/industries/new-energy-pv-ev-parts/",
        label: "New Energy / PV / EV Parts",
      },
    ],
  },
  { href: "/how-it-works", label: "How It Works" },
  { href: "/cases", label: "Cases" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url?.pathname || "/";
const isActive = (href) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
---

<div class="topbar">
  <Container variant="wide">
    <div class="navShell">
      <a class="brand" href="/">
        <img src="/images/brand/certirunlogo.webp" alt="CertiRun logo" class="brandLogoImage" />
      </a>

      <nav class="menu" aria-label="Primary navigation">
        {nav.map((item) => (
          item.children ? (
            <div class="navDropdown">
              <a href={item.href} class={isActive(item.href) ? "active" : ""} aria-haspopup="true">
                {item.label}
              </a>
              <div class="navDropdownPanel" aria-label="Industry pages">
                {item.children.map((child) => (
                  <a href={child.href}>{child.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class={isActive(item.href) ? "active" : ""}>
              {item.label}
            </a>
          )
        ))}
      </nav>
    </div>
  </Container>
</div>
