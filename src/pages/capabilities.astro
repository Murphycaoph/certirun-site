---
import BaseLayout from "../layouts/BaseLayout.astro";

const serviceIcons = {
  search: `
    <circle cx="11" cy="11" r="6"></circle>
    <path d="m16 16 4 4"></path>
  `,
  verify: `
    <path d="M12 3 19 6v5c0 5-3 8-7 10-4-2-7-5-7-10V6z"></path>
    <path d="m9 12 2 2 4-5"></path>
  `,
  coordinate: `
    <path d="M4 7h6"></path>
    <path d="M14 7h6"></path>
    <path d="M4 17h6"></path>
    <path d="M14 17h6"></path>
    <circle cx="12" cy="7" r="2"></circle>
    <circle cx="12" cy="17" r="2"></circle>
  `,
  logistics: `
    <path d="M3 6h11v10H3z"></path>
    <path d="M14 10h4l3 3v3h-7z"></path>
    <circle cx="7" cy="18" r="2"></circle>
    <circle cx="17" cy="18" r="2"></circle>
  `,
  document: `
    <path d="M7 3h10v18H7z"></path>
    <path d="M10 8h4"></path>
    <path d="M10 12h4"></path>
    <path d="M10 16h3"></path>
  `,
  control: `
    <circle cx="12" cy="12" r="8"></circle>
    <circle cx="12" cy="12" r="3"></circle>
    <path d="M12 2v4"></path>
    <path d="M12 18v4"></path>
    <path d="M2 12h4"></path>
    <path d="M18 12h4"></path>
  `,
  arrow: `
    <path d="M5 12h14"></path>
    <path d="m13 6 6 6-6 6"></path>
  `,
};

const page = {
  hero: {
    eyebrow: "CertiRun / Services",
    title: "Services for controlled sourcing execution.",
    subtitle:
      "CertiRun helps overseas buyers turn product requests into structured supplier comparison, verification checkpoints, and delivery follow-up.",
  },
  services: [
    {
      icon: "search",
      title: "Supplier Sourcing",
      description:
        "Find and compare supplier options based on category fit, production scope, response quality, and execution readiness.",
      features: ["Supplier shortlist", "Quotation comparison", "Risk notes"],
    },
    {
      icon: "verify",
      title: "Verification Checkpoints",
      description:
        "Review the key details that usually create sourcing disputes before the order moves too far into execution.",
      features: ["Product detail review", "Packing status check", "Readiness confirmation"],
    },
    {
      icon: "coordinate",
      title: "Order Coordination",
      description:
        "Keep supplier communication, timelines, sample status, and buyer decisions organized across the execution process.",
      features: ["Follow-up tracking", "Decision records", "Supplier alignment"],
    },
    {
      icon: "logistics",
      title: "Delivery Follow-Up",
      description:
        "Support shipment readiness, document accuracy, dispatch updates, and post-shipment communication.",
      features: ["Shipment readiness", "Export document review", "Delivery visibility"],
    },
    {
      icon: "document",
      title: "Document Control",
      description:
        "Help keep quotations, packing information, order details, and export documents clear and consistent.",
      features: ["Quote structure", "Packing details", "Document accuracy"],
    },
    {
      icon: "control",
      title: "Execution Visibility",
      description:
        "Create a practical operating layer so buyers know what is confirmed, what is pending, and what needs attention.",
      features: ["Status tracking", "Issue escalation", "Buyer-side clarity"],
    },
  ],
  process: [
    {
      service: "Supplier Sourcing",
      steps: ["Clarify product scope", "Screen supplier fit", "Collect quotations", "Compare options"],
    },
    {
      service: "Verification Checkpoints",
      steps: ["Confirm order details", "Check packing status", "Review documents", "Report readiness"],
    },
    {
      service: "Delivery Follow-Up",
      steps: ["Align shipment plan", "Track dispatch status", "Check export documents", "Keep buyer updated"],
    },
  ],
  differentiation: [
    {
      title: "Structured Before Fast",
      description:
        "The goal is not to rush supplier contact. The goal is to make the request clear enough that supplier responses can be compared.",
    },
    {
      title: "Execution Over Claims",
      description:
        "CertiRun focuses on checkpoints, records, and follow-up rather than broad promises that do not help buyers make decisions.",
    },
    {
      title: "Built For Multi-Supplier Work",
      description:
        "Many sourcing projects involve several suppliers, SKUs, and shipment constraints. The service model is designed for that reality.",
    },
  ],
  cta: {
    title: "Start with a structured service path.",
    subtitle:
      "Send the product scope, target quantity, and delivery market. CertiRun will help define the next sourcing step.",
    button: "Start Sourcing",
    href: "/contact",
  },
};
---

<BaseLayout
  title="Services | CertiRun"
  description="CertiRun services for supplier sourcing, verification checkpoints, order coordination, document control, and delivery follow-up."
  canonical="/capabilities/"
>
  <section class="subpageHero">
    <div class="container wide">
      <p class="eyebrow">{page.hero.eyebrow}</p>
      <h1>{page.hero.title}</h1>
      <p class="lead">{page.hero.subtitle}</p>
    </div>
  </section>

  <div class="pageShell">
    <section class="servicesOverview">
      <div class="container wide">
        <div class="servicesIntro">
          <p class="servicesBadge">Services</p>
          <h2>Operational support across the sourcing cycle</h2>
          <p>
            Each service is designed to make sourcing work more visible,
            comparable, and easier to control before commitments turn into risk.
          </p>
        </div>

        <div class="servicesGrid">
          {page.services.map((service) => (
            <article class="serviceCard">
              <div class="serviceCardTop">
                <span class="serviceIcon">
                  <svg class="serviceIconSvg" viewBox="0 0 24 24" aria-hidden="true" set:html={serviceIcons[service.icon]} />
                </span>
              </div>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <ul>
                {service.features.map((feature) => (
                  <li>{feature}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="processSection">
      <div class="container wide">
        <div class="sectionHeading">
          <p class="servicesBadge">Process</p>
          <h2>How each service becomes a practical workflow</h2>
          <p>
            Services are delivered as concrete steps, not vague support. Each track
            has a clear sequence and visible output.
          </p>
        </div>

        <div class="processGrid">
          {page.process.map((item) => (
            <article class="processCard">
              <h3>{item.service}</h3>
              <ol>
                {item.steps.map((step, index) => (
                  <li>
                    <span>{String(index + 1).padStart(2, "0")}</span>
                    {step}
                  </li>
                ))}
              </ol>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="differenceSection">
      <div class="container wide">
        <div class="sectionHeading">
          <p class="servicesBadge">Differentiation</p>
          <h2>What makes the service model different</h2>
          <p>
            The model is built for practical buyer-side control: clear inputs,
            comparable options, and visible handoffs.
          </p>
        </div>

        <div class="differenceGrid">
          {page.differentiation.map((item) => (
            <article class="differenceCard">
              <span class="cardRule"></span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="servicesCtaSection">
      <div class="container wide">
        <div class="servicesCta">
          <p class="servicesBadge">Next Step</p>
          <h2>{page.cta.title}</h2>
          <p>{page.cta.subtitle}</p>
          <a class="ctaAction" href={page.cta.href}>
            <span>{page.cta.button}</span>
            <svg class="serviceIconSvg" viewBox="0 0 24 24" aria-hidden="true" set:html={serviceIcons.arrow} />
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .servicesOverview,
  .processSection,
  .differenceSection{
    padding:76px 0 28px;
    background:#fff;
  }

  .processSection,
  .differenceSection{
    padding-top:40px;
  }

  .servicesIntro,
  .sectionHeading{
    max-width:700px;
    margin-bottom:30px;
  }

  .servicesBadge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:30px;
    padding:0 14px;
    margin:0 0 22px;
    border:1px solid rgba(10,37,64,.28);
    border-radius:8px;
    background:#F1F4F8;
    color:#0A2540;
    font-family:"Work Sans", Arial, sans-serif;
    font-size:.72rem;
    font-weight:800;
    line-height:1;
    letter-spacing:.16em;
    text-transform:uppercase;
  }

  .servicesIntro h2,
  .sectionHeading h2,
  .servicesCta h2{
    max-width:760px;
    font-size:clamp(2rem, 3.2vw, 3.45rem);
    line-height:1.1;
    letter-spacing:-.035em;
    font-weight:800;
  }

  .servicesIntro p:not(.servicesBadge),
  .sectionHeading p:not(.servicesBadge),
  .servicesCta p:not(.servicesBadge){
    margin-top:18px;
    max-width:680px;
    color:var(--text-secondary);
    font-size:var(--type-body-lg);
    line-height:1.65;
  }

  .servicesGrid,
  .processGrid,
  .differenceGrid{
    display:grid;
    grid-template-columns:repeat(3, minmax(0, 1fr));
    gap:22px;
  }

  .serviceCard,
  .processCard,
  .differenceCard{
    display:grid;
    align-content:start;
    min-height:272px;
    padding:28px;
    border:1px solid var(--border);
    border-radius:8px;
    background:#fff;
    box-shadow:0 8px 22px rgba(10,37,64,.04);
    transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease;
  }

  .serviceCard:hover,
  .processCard:hover,
  .differenceCard:hover{
    transform:translateY(-2px);
    border-color:rgba(10,37,64,.18);
    box-shadow:0 14px 32px rgba(10,37,64,.08);
  }

  .serviceCardTop{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    margin-bottom:24px;
  }

  .serviceIcon{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:58px;
    height:58px;
    border-radius:14px;
    background:#F1F4F8;
    color:var(--accent);
  }

  .serviceIconSvg{
    width:32px;
    height:32px;
    fill:none;
    stroke:currentColor;
    stroke-width:1.7;
    stroke-linecap:round;
    stroke-linejoin:round;
  }

  .serviceCard h3,
  .processCard h3,
  .differenceCard h3{
    max-width:360px;
    font-size:1.18rem;
    font-weight:800;
    line-height:1.2;
  }

  .serviceCard p,
  .differenceCard p{
    margin-top:18px;
    color:var(--text-secondary);
    line-height:1.62;
  }

  .serviceCard ul{
    display:grid;
    gap:10px;
    margin:22px 0 0;
    padding:0;
    list-style:none;
  }

  .serviceCard li{
    position:relative;
    padding-left:18px;
    color:var(--text-secondary);
    line-height:1.5;
  }

  .serviceCard li::before{
    content:"";
    position:absolute;
    left:0;
    top:.65em;
    width:6px;
    height:6px;
    border-radius:999px;
    background:var(--accent);
  }

  .processCard ol{
    display:grid;
    gap:14px;
    margin:24px 0 0;
    padding:0;
    list-style:none;
  }

  .processCard li{
    display:grid;
    grid-template-columns:44px minmax(0, 1fr);
    align-items:center;
    gap:14px;
    color:var(--text-secondary);
    line-height:1.45;
  }

  .processCard li span{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:34px;
    height:34px;
    border:1px solid rgba(10,37,64,.18);
    border-radius:4px;
    color:var(--accent);
    font-family:"Work Sans", Arial, sans-serif;
    font-size:.7rem;
    font-weight:800;
  }

  .cardRule{
    width:42px;
    height:2px;
    margin-bottom:20px;
    background:var(--accent);
  }

  .servicesCtaSection{
    padding:42px 0 78px;
    background:#fff;
  }

  .servicesCta{
    display:grid;
    justify-items:center;
    text-align:center;
    gap:18px;
    padding:42px 32px 46px;
    border-radius:8px;
    background:
      radial-gradient(circle at 82% 35%, rgba(47,128,237,.13), transparent 28%),
      linear-gradient(135deg, #F4F8FD 0%, #EEF5FC 100%);
    overflow:hidden;
  }

  .servicesCta .servicesBadge{
    margin:0;
  }

  .servicesCta h2{
    color:var(--accent);
  }

  .ctaAction{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:16px;
    min-width:210px;
    min-height:58px;
    padding:0 28px;
    border-radius:8px;
    background:var(--accent);
    color:#fff;
    font-weight:800;
    box-shadow:0 12px 28px rgba(10,37,64,.18);
    transition:transform .16s ease, background-color .16s ease;
  }

  .ctaAction:hover{
    transform:translateY(-2px);
    background:var(--accent-hover);
  }

  .ctaAction .serviceIconSvg{
    width:22px;
    height:22px;
    stroke-width:2;
  }

  @media (max-width: 900px){
    .servicesOverview,
    .processSection,
    .differenceSection{
      padding:56px 0 20px;
    }

    .servicesGrid,
    .processGrid,
    .differenceGrid{
      grid-template-columns:1fr;
    }

    .serviceCard,
    .processCard,
    .differenceCard{
      min-height:auto;
    }

    .servicesCtaSection{
      padding:32px 0 56px;
    }
  }
</style>
