---
import BaseLayout from "../layouts/BaseLayout.astro";

const principles = [
  {
    title: "Clear Inputs",
    description:
      "Good sourcing starts with clear product scope, target quantity, standards, packing needs, and delivery expectations.",
  },
  {
    title: "Visible Checkpoints",
    description:
      "Each handoff should have a record. CertiRun focuses on what is confirmed, what is pending, and what needs review.",
  },
  {
    title: "Practical Supplier Control",
    description:
      "Supplier comparison only helps when the details are organized in a way buyers can actually use.",
  },
  {
    title: "Execution Discipline",
    description:
      "Sourcing does not end at quotation. Follow-up, verification, documents, and dispatch status all need structure.",
  },
];
---

<BaseLayout
  title="About CertiRun"
  description="About CertiRun and its approach to structured sourcing, verification, and delivery follow-up."
  canonical="/about/"
>
  <section class="subpageHero">
    <div class="container wide">
      <p class="eyebrow">CertiRun / About</p>
      <h1>Built for buyers who need sourcing to stay controlled.</h1>
      <p class="lead">
        CertiRun supports overseas buyers with structured supplier coordination,
        verification checkpoints, and delivery follow-up across China sourcing workflows.
      </p>
    </div>
  </section>

  <div class="pageShell">
    <section class="aboutIntroSection">
      <div class="container wide">
        <div class="aboutSplit">
          <div>
            <p class="pageBadge">Who We Are</p>
            <h2>A practical operating layer between buyer requirements and supplier execution.</h2>
          </div>
          <p>
            CertiRun is designed for B2B buyers who need more than a supplier name.
            We help structure the work between request clarification, supplier comparison,
            verification, document control, and delivery communication.
          </p>
        </div>
      </div>
    </section>

    <section class="principlesSection">
      <div class="container wide">
        <div class="sectionHeading">
          <p class="pageBadge">Principles</p>
          <h2>How we approach sourcing support</h2>
          <p>
            The operating principle is simple: reduce ambiguity before it becomes
            cost, delay, or dispute.
          </p>
        </div>
        <div class="principlesGrid">
          {principles.map((item) => (
            <article class="principleCard">
              <span class="cardRule"></span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="aboutCtaSection">
      <div class="container wide">
        <div class="aboutCta">
          <p class="pageBadge">Next Step</p>
          <h2>Work with a sourcing process that stays visible.</h2>
          <p>Send the product scope and current sourcing challenge. CertiRun can help define a clearer path.</p>
          <a class="ctaAction" href="/contact">Contact CertiRun</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .aboutIntroSection,.principlesSection{ padding:76px 0 28px; background:#fff; }
  .principlesSection{ padding-top:40px; }
  .aboutSplit{ display:grid; grid-template-columns:minmax(0,.95fr) minmax(0,1.05fr); gap:64px; align-items:start; }
  .pageBadge{
    display:inline-flex; align-items:center; justify-content:center; min-height:30px;
    padding:0 14px; margin:0 0 22px; border:1px solid rgba(10,37,64,.28);
    border-radius:8px; background:#F1F4F8; color:#0A2540;
    font-family:"Work Sans",Arial,sans-serif; font-size:.72rem; font-weight:800;
    line-height:1; letter-spacing:.16em; text-transform:uppercase;
  }
  .aboutSplit h2,.sectionHeading h2,.aboutCta h2{
    max-width:760px; font-size:clamp(2rem,3.2vw,3.45rem); line-height:1.1;
    letter-spacing:-.035em; font-weight:800;
  }
  .aboutSplit > p,.sectionHeading p:not(.pageBadge),.aboutCta p:not(.pageBadge){
    color:var(--text-secondary); font-size:var(--type-body-lg); line-height:1.75;
  }
  .sectionHeading{ max-width:700px; margin-bottom:30px; }
  .sectionHeading p:not(.pageBadge),.aboutCta p:not(.pageBadge){ margin-top:18px; max-width:680px; }
  .principlesGrid{ display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:22px; }
  .principleCard{
    display:grid; align-content:start; min-height:240px; padding:28px;
    border:1px solid var(--border); border-radius:8px; background:#fff;
    box-shadow:0 8px 22px rgba(10,37,64,.04);
    transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease;
  }
  .principleCard:hover{ transform:translateY(-2px); border-color:rgba(10,37,64,.18); box-shadow:0 14px 32px rgba(10,37,64,.08); }
  .cardRule{ width:42px; height:2px; margin-bottom:20px; background:var(--accent); }
  .principleCard h3{ font-size:1.12rem; font-weight:800; }
  .principleCard p{ margin-top:18px; color:var(--text-secondary); line-height:1.62; }
  .aboutCtaSection{ padding:42px 0 78px; background:#fff; }
  .aboutCta{
    display:grid; justify-items:center; text-align:center; gap:18px; padding:42px 32px 46px;
    border-radius:8px; background:linear-gradient(135deg,#F4F8FD 0%,#EEF5FC 100%);
  }
  .aboutCta .pageBadge{ margin:0; }
  .aboutCta h2{ color:var(--accent); }
  .ctaAction{
    display:inline-flex; align-items:center; justify-content:center; min-width:210px; min-height:58px;
    padding:0 28px; border-radius:8px; background:var(--accent); color:#fff; font-weight:800;
    box-shadow:0 12px 28px rgba(10,37,64,.18); transition:transform .16s ease, background-color .16s ease;
  }
  .ctaAction:hover{ transform:translateY(-2px); background:var(--accent-hover); }
  @media (max-width:900px){
    .aboutIntroSection,.principlesSection{ padding:56px 0 20px; }
    .aboutSplit,.principlesGrid{ grid-template-columns:1fr; }
    .principleCard{ min-height:auto; }
    .aboutCtaSection{ padding:32px 0 56px; }
  }
</style>
