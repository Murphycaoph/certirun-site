---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import HeadingBlock from "../components/ui/HeadingBlock.astro";
import Card from "../components/ui/Card.astro";
---

<BaseLayout
  title="CertiRun | Placeholder"
  description="Neutral placeholder response page."
  canonical="/thank-you/"
  robots="noindex, nofollow"
>
  <div class="container wide pageShell">
    <section class="heroBlock">
      <p class="eyebrow">CertiRun / Placeholder</p>
      <h1>Placeholder response page.</h1>
      <p class="lead">
        This route remains available as a neutral endpoint while future form flows are
        redesigned.
      </p>
    </section>

    <Section surface="panel">
      <div class="sectionStack">
        <HeadingBlock
          eyebrow="Response"
          title="Route retained for future form flows"
          description="This endpoint stays in place so future contact journeys can plug into the system without rebuilding basic route infrastructure."
        />
        <div class="cardGrid two">
          <Card compact={true}>
            <h3>Current role</h3>
            <p>A neutral acknowledgement page for placeholder and future form submissions.</p>
          </Card>
          <Card compact={true}>
            <h3>Next role</h3>
            <p>Can later be refined into a real confirmation state once the final form experience is defined.</p>
          </Card>
        </div>
      </div>
    </Section>
  </div>
</BaseLayout>
