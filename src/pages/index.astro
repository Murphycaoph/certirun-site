---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroVisualPanel from "../components/HeroVisualPanel.astro";
import CategoryIcon from "../components/CategoryIcon.astro";

const categoryLinks = [
  {
    href: "/industries/electronics-electronic-components/",
    zh: "电子与电子元器件",
    en: "Electronics & Electronic Components",
    icon: "electronics",
  },
  {
    href: "/industries/machinery-industrial-equipment/",
    zh: "机械与机电设备",
    en: "Machinery & Industrial Equipment",
    icon: "machinery",
  },
  {
    href: "/industries/hardware-products/",
    zh: "五金产品",
    en: "Hardware products",
    icon: "hardware",
  },
  {
    href: "/industries/vehicle-parts/",
    zh: "商用车及乘用车零部件",
    en: "Commercial vehicle and passenger vehicle parts",
    icon: "vehicle",
  },
  {
    href: "/industries/new-energy-pv-ev-parts/",
    zh: "新能源与光伏 / 电动车零部件",
    en: "New Energy / PV / EV Parts",
    icon: "energy",
  },
];
---

<BaseLayout
  title="CertiRun | Operational Verification"
  description="Industrial verification and operational control for sourcing, logistics, and execution workflows."
  canonical="/"
>
  <section class="heroFrame">
    <div class="container wide heroTextRail">
      <div class="heroContent">
        <div class="heroEyebrowRow">
          <span class="heroLine"></span>
          <p class="eyebrow">Operational Excellence Redefined</p>
        </div>
        <h1>
          <span class="heroTitleLine">Reliable China Sourcing,</span>
          <span class="heroTitleLine heroTitleAccent">Beyond Just Finding Suppliers.</span>
        </h1>
        <p class="lead">
          We support overseas buyers with sourcing, verification, coordination, and
          delivery follow-up across multiple product categories in China.
        </p>
        <div class="buttonRow">
          <a class="button secondary" href="/contact">Start Sourcing</a>
          <a class="button outline" href="/industries">See Industries</a>
        </div>
      </div>
    </div>

    <div class="heroBleedVisual">
      <HeroVisualPanel />
    </div>
  </section>

  <section class="logoStrip">
    <div class="container wide logoStripInner">
      {categoryLinks.map((item) => (
        <a href={item.href} class="categoryTile">
          <CategoryIcon name={item.icon} />
          <span class="categoryText">
            <strong>{item.zh}</strong>
            <span>{item.en}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="sectionBlock">
    <div class="container wide">
      <div class="sectionIntro">
        <h2>Precision Services</h2>
        <p>
          Operational verification layers designed for high-velocity sourcing and
          logistics workflows.
        </p>
      </div>

      <div class="featureGrid">
        <article class="featurePanel">
          <div class="featureIcon"></div>
          <h3>Network Validation</h3>
          <p>
            Structured oversight for supplier coordination, handoff checkpoints, and
            cross-border execution visibility.
          </p>
        </article>

        <article class="featurePanel">
          <div class="featureIcon"></div>
          <h3>Certified Operations</h3>
          <p>
            Consistent review layers for documents, routing, and delivery readiness
            across every operational touchpoint.
          </p>
        </article>

        <article class="featurePanel">
          <div class="featureIcon"></div>
          <h3>Compliance Control</h3>
          <p>
            Clear operating standards for regulated workflows, partner alignment, and
            execution confidence.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="commandSection">
    <div class="container wide commandGrid">
      <div class="commandCopy">
        <div class="statusPill">System Status: Active</div>
        <h2>Operational Command</h2>
        <p>
          A single control surface for verification logic, sourcing readiness, and
          movement integrity. Monitor checkpoints, audit handoffs, and maintain
          execution discipline from one operational layer.
        </p>

        <div class="commandList">
          <div class="commandItem">
            <span class="commandCheck"></span>
            <div>
              <h3>Identity-Locked Verification</h3>
              <p>Structured validation standards at each transfer, review, and release point.</p>
            </div>
          </div>

          <div class="commandItem">
            <span class="commandCheck"></span>
            <div>
              <h3>Traceable Audit Chains</h3>
              <p>Operational records designed to reduce ambiguity across teams and geographies.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="commandPanel">
        <div class="commandTopbar">
          <div class="commandDots">
            <span></span><span></span><span></span>
          </div>
          <div class="commandLabel">LIVE_FEED_TRANSIT_V1</div>
        </div>

        <div class="statsGrid">
          <div class="statCard">
            <small>Total Verified Units</small>
            <strong>14,292,042</strong>
            <div class="statBar"><span class="brand-accent"></span></div>
          </div>
          <div class="statCard">
            <small>Network Uptime</small>
            <strong>99.998%</strong>
            <div class="statBar">
              <span class="green"></span>
              <span class="green"></span>
              <span class="green"></span>
              <span class="green"></span>
            </div>
          </div>
        </div>

        <div class="feedList">
          <div class="feedRow">
            <div><span class="pulse brand-accent"></span> HUB_CENTRAL_SHANGHAI: VERIFIED</div>
            <small>12:04:12</small>
          </div>
          <div class="feedRow">
            <div><span class="pulse brand-accent"></span> PORT_ROTTERDAM_GATE4: IN_TRANSIT</div>
            <small>12:04:09</small>
          </div>
          <div class="feedRow">
            <div><span class="pulse green"></span> AIR_FREIGHT_744: SECURE_LOCK</div>
            <small>12:03:55</small>
          </div>
        </div>

        <div class="floatingMetric">
          <strong>2.4s</strong>
          <span>AVG VERIFICATION TIME</span>
        </div>
      </div>
    </div>
  </section>

  <section class="ctaBand">
    <div class="container wide ctaBandInner">
      <h2>Ready for Operational Certainty?</h2>
      <p>
        Start with a structured CertiRun layer for execution, verification, and partner
        coordination.
      </p>
      <a class="button secondary ctaButton" href="/contact">Start Your Verification</a>
    </div>
  </section>
</BaseLayout>
