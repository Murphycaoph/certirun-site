---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BrandInquiryPage from "../../../components/BrandInquiryPage.astro";
import { brandPageContent } from "../../../lib/brandPlatformPages";

const page = brandPageContent.man;
---

<BaseLayout
  title={page.seoTitle}
  description={page.seoDescription}
  keywords={page.seoKeywords}
  canonical={page.canonical}
  ogImage={page.ogImage}
  jsonLd={page.jsonLd}
  robots={page.robots}
>
  <BrandInquiryPage page={page} />
</BaseLayout>
