const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Sinotruk Platform Preview",
    description:
      "Preview page for a Sinotruk platform-led inquiry browser that helps buyers narrow platform and support scope before chatting on WhatsApp.",
    url: "https://certirun.com/product/brand/sinotruk-platform-preview/",
  },
];
---

<BaseLayout
  title="Sinotruk Platform Preview | CertiRun"
  description="Preview a platform-led Sinotruk inquiry page that lets buyers browse assemblies, platforms, and supported parts scope before contacting CertiRun."
  keywords={["Sinotruk platform preview", "Sinotruk parts support", "Sinotruk engine platform", "Sinotruk gearbox support", "Sinotruk WhatsApp inquiry"]}
  canonical="/product/brand/sinotruk-platform-preview/"
  ogImage="/images/brands/sinotruk.png"
  jsonLd={jsonLd}
  robots="noindex,nofollow"
>
  <style>
    :root{ --bg:#eef3f7; --text:#1d2a36; --muted:#5f6d86; --line:rgba(29,42,54,.10); --brand:#3957E9; }
    :global(main){ background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%); }
    :global(.topbar){ background:#111F43 !important; background-color:#111F43 !important; opacity:1 !important; backdrop-filter:none !important; -webkit-backdrop-filter:none !important; border-bottom:1px solid #111F43 !important; box-shadow:none !important; }
    :global(.menu), :global(.menu a), :global(.menu a:hover){ color:#fff; }
    :global(.menu a.active), :global(.drawerNav a.active){ color:#fff; background:rgba(57,87,233,.18); border-color:rgba(57,87,233,.32); }
    :global(.cta){ background:#3957E9; color:#fff; }
    .hero{ position:relative; padding:46px 0 20px; border-bottom:1px solid var(--line); overflow:hidden; isolation:isolate; background:#0b1020; }
    .heroBg{ position:absolute; inset:0; z-index:-2; background:url("/images/hero-04-logistics-truck.webp") center/cover no-repeat; filter:blur(2px) saturate(.95) contrast(.95) brightness(.88); transform:scale(1.03); }
    .overlay{ position:absolute; inset:0; z-index:-1; background:linear-gradient(180deg, rgba(11,16,32,.28) 0%, rgba(11,16,32,.86) 72%, rgba(11,16,32,1) 100%), radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.22), transparent 60%); }
    .heroInner{ position:relative; padding:2px 0 22px; display:grid; grid-template-columns:minmax(0, 1.1fr) minmax(320px, .9fr); gap:22px; align-items:end; }
    .eyebrow{ margin:0 0 10px; font-size:12px; font-weight:900; letter-spacing:.14em; text-transform:uppercase; color:rgba(232,240,255,.76); }
    h1{ margin:0 0 14px; font-size:46px; line-height:1.04; letter-spacing:-.65px; color:#fff; max-width:740px; }
    .heroLead{ margin:0; max-width:740px; color:rgba(232,240,255,.84); line-height:1.8; }
    .heroActions{ display:flex; gap:10px; flex-wrap:wrap; margin-top:18px; }
    .heroActions .btn.primary, .ctaBlock .btn.primary{ color:#fff; }
    .heroPanel{ padding:20px 22px; border-radius:26px; border:1px solid rgba(255,255,255,.12); background:linear-gradient(180deg, rgba(18,26,46,.72), rgba(18,26,46,.52)); backdrop-filter:blur(8px); box-shadow:0 20px 60px rgba(6,11,26,.28); }
    .heroPanel b{ display:block; margin-bottom:12px; color:#fff; font-size:18px; }
    .heroList{ display:grid; gap:10px; }
    .heroListItem{ display:flex; gap:10px; align-items:flex-start; color:rgba(232,240,255,.82); line-height:1.7; }
    .heroDot{ width:10px; height:10px; border-radius:999px; background:#5b7cff; margin-top:8px; flex:0 0 auto; }
    .section{ padding:26px 0; }
    .sectionTitle{ margin:0 0 10px; font-size:28px; line-height:1.2; color:#1d2a36; }
    .sectionDesc{ margin:0 0 16px; color:var(--muted); line-height:1.75; max-width:860px; }
    .grid2{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:16px; }
    .grid3{ display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; }
    .card{ background:#fff; border:1px solid var(--line); border-radius:22px; padding:18px; box-shadow:0 16px 40px rgba(24,39,56,.05); }
    .card b{ display:block; margin-bottom:8px; color:#1d2a36; font-size:18px; line-height:1.35; }
    .card p{ margin:0; color:var(--muted); line-height:1.75; }
    .chipWrap{ display:flex; gap:10px; flex-wrap:wrap; }
    .chip{ display:inline-flex; align-items:center; padding:10px 14px; border-radius:999px; background:#fff; border:1px solid rgba(29,42,54,.10); color:#1d2a36; font-weight:700; }
    .bulletList{ list-style:none; padding:0; margin:0; display:grid; gap:10px; }
    .bulletItem{ display:flex; gap:10px; align-items:flex-start; color:var(--muted); line-height:1.7; }
    .dot{ width:10px; height:10px; border-radius:999px; background:#5b7cff; margin-top:8px; flex:0 0 auto; }
    .faq{ display:grid; gap:12px; }
    .faqItem{ background:#fff; border:1px solid var(--line); border-radius:20px; padding:16px 18px; box-shadow:0 16px 40px rgba(24,39,56,.04); }
    .faqItem strong{ display:block; margin-bottom:8px; color:#1d2a36; }
    .faqItem p{ margin:0; color:var(--muted); line-height:1.75; }
    .ctaBlock{ border-radius:20px; padding:18px; background:linear-gradient(135deg, rgba(57,87,233,.10), rgba(255,255,255,.92)); border:1px solid rgba(57,87,233,.16); display:flex; justify-content:space-between; align-items:center; gap:14px; box-shadow:0 16px 40px rgba(24,39,56,.05); }
    .ctaBlock .left b{ display:block; margin-bottom:6px; color:#1d2a36; }
    .ctaBlock .left p{ margin:0; color:var(--muted); line-height:1.75; max-width:760px; }
    :global(.footerWrap){ background:transparent; border-top:1px solid rgba(29,42,54,.10); }
    :global(.footerTitle), :global(.footerNav strong){ color:#1d2a36; }
    :global(.footer), :global(.footerNav span){ color:var(--muted); }
    :global(.footerNav a){ background:#fff; border-color:rgba(29,42,54,.10); }
    @media (max-width: 980px){ .heroInner, .grid2, .grid3{ grid-template-columns:1fr; } h1{ font-size:38px; } .ctaBlock{ flex-direction:column; align-items:flex-start; } }
  </style>

  <section class="hero">
    <div class="heroBg" aria-hidden="true"></div>
    <div class="overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="heroInner">
        <div>
          <p class="eyebrow">CertiRun / Brand Sourcing Preview</p>
          <h1>Send your Sinotruk parts inquiry and narrow the right platform before you chat with us</h1>
          <p class="heroLead">Narrow down the right platform before you reach out, so we can start from a clearer scope and move faster on matching and quotation.</p>
          <div class="heroActions">
            <a class="btn primary" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">Chat on WhatsApp</a>
            <a class="btn" href="#what-to-send">See What to Send</a>
          </div>
        </div>
        <aside class="heroPanel">
          <b>What to send for a faster reply</b>
          <div class="heroList">
            {matchingInputs.slice(0, 5).map((item) => (
              <div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Have you run into these issues when sourcing Sinotruk parts?</h2>
      <div class="grid3">
        {painPoints.map((item) => (
          <div class="card"><b>{item.title}</b><p>{item.desc}</p></div>
        ))}
      </div>
    </div>
  </section>

  <BrandPlatformExplorer
    id="sinotruk-platform-browser"
    eyebrow="Sinotruk platform browser"
    title="Browse Sinotruk platforms and parts support"
    description=""
    assemblies={sinotrukAssemblies}
    whatsappHref={WHATSAPP_URL}
    fallbackText="Not all supported parts are listed here. If you have a specific request, just reach out and we'll check it for you."
    fallbackCtaLabel="Chat on WhatsApp"
  />

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">What happens after you send the inquiry</h2>
      <div class="grid2">
        {processSteps.map((step) => (
          <div class="card"><b>{step.title}</b><p>{step.desc}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Why buyers use us for Sinotruk inquiries</h2>
      <div class="grid3">
        {whyWorkWithUs.map((item) => (
          <div class="card"><b>{item.title}</b><p>{item.desc}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">FAQ</h2>
      <div class="faq">
        {faq.map((item) => (
          <div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Need to start from the part category instead?</h2>
      <div class="grid3">
        {relatedPaths.map((item) => (
          <div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="ctaBlock">
        <div class="left">
          <b>Ready to send your Sinotruk inquiry?</b>
          <p>Send the OE number, VIN, photos, part list, or old supplier references you already have. We will review the inquiry, confirm the matching scope, and reply with the next workable step.</p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a class="btn primary" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">Chat on WhatsApp</a>
          <a class="btn" href="/contact">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
