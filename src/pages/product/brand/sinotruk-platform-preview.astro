        supportGroups: [
          { title: "Common support scope", items: ["Air valves", "Brake chamber items", "Actuation parts", "Air dryer support"] },
          { title: "Related support", items: ["Push rods", "Clevis items", "Repair diaphragms", "Fittings"] },
