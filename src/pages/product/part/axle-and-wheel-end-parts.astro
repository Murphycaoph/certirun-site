---
import PartInquiryPage from "../../../components/PartInquiryPage.astro";

const painPoints = [
  {
    title: "Same wheel-end name, different fitment",
    desc: "Hub, bearing, seal, and wheel-end items can share a broad name but differ by axle application, dimensions, or hardware layout.",
  },
  {
    title: "Wrong hub or bearing spec is costly",
    desc: "Without clear dimensions and axle references, suppliers may quote items that fit the label but not the assembly.",
  },
  {
    title: "Wheel-end RFQs get split too easily",
    desc: "Hubs, bearings, seals, and hardware often belong in one RFQ, but they are harder to compare when quoted separately.",
  },
];

const matchingInputs = [
  "OE number or part number",
  "Vehicle or axle application",
  "Hub, bearing, or seal dimensions",
  "Part photos",
  "Quantity list and destination",
];

const processSteps = [
  { title: "You send the details", desc: "Share the references you already have, including OE numbers, axle application, dimensions, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical scope before quotation starts so wheel-end items stay aligned." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on fitment, quality level, and execution instead of price alone." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we continue with QC, packing checks, documents, and shipment coordination." },
];

const whyWorkWithUs = [
  {
    title: "We check fitment before quoting",
    desc: "Wheel-end parts depend on axle application, hub size, bearing spec, and seal dimensions, so we confirm first.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same fitment and execution basis.",
  },
  {
    title: "We handle mixed axle-category demand",
    desc: "We can organize hubs, bearings, seals, shafts, and hardware into one workable order.",
  },
];

const faq = [
  { q: "Can I start without OE numbers?", a: "Yes. Axle application, hub dimensions, bearing references, seal sizes, or photos can also work." },
  { q: "Can you handle mixed wheel-end parts in one order?", a: "Yes. We can organize multiple axle and wheel-end items into one structured inquiry and shipment plan." },
  { q: "Do you support inspection before shipment?", a: "Yes. We follow up on QC, packing checks, and shipment coordination." },
];

const relatedPaths = [
  { title: "FAW parts sourcing", desc: "For axle-led RFQs tied to a known truck platform.", href: "/product/brand/faw/" },
  { title: "Volvo Truck parts sourcing", desc: "For wheel-end and axle-category demand under Volvo truck applications.", href: "/product/brand/volvo-truck/" },
  { title: "Suspension parts", desc: "If the RFQ also includes chassis-side wear items.", href: "/product/part/suspension-parts/" },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Axle And Wheel-End Parts Sourcing from China", description: "Send your axle and wheel-end parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certirun.com/product/part/axle-and-wheel-end-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certirun.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certirun.com/product/" }, { "@type": "ListItem", position: 3, name: "Axle And Wheel-End Parts", item: "https://certirun.com/product/part/axle-and-wheel-end-parts/" } ] },
];
---

<PartInquiryPage
  pageTitle="Send Your Axle And Wheel-End Parts Inquiry | Clear Matching and Workable Quotes"
  pageDescription="Send your axle and wheel-end parts inquiry with OE numbers, specs, photos, or part lists. CertiRun checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={["axle and wheel-end parts sourcing from China", "wheel-end parts RFQ", "axle parts supplier China", "wheel-end quote support", "axle and wheel-end inquiry"]}
  canonical="/product/part/axle-and-wheel-end-parts/"
  ogImage="/images/assemblies/assembly-axle.png"
  jsonLd={jsonLd}
  systemLabel="Axle and wheel-end parts"
  heroTitle="Send your axle and wheel-end parts inquiry and get clearer matching"
  heroLead="Send OE numbers, axle application, hub and bearing references, seal sizes, photos, or your parts list. We review the scope first, then move into quotation, inspection, and shipment follow-up."
  primaryCtaLabel="Send Axle Inquiry"
  painPointsHeading="Running into these issues when sourcing axle and wheel-end parts?"
  painPoints={painPoints}
  matchingInputs={matchingInputs}
  processSteps={processSteps}
  whyWorkWithUsHeading="Why buyers use us for axle and wheel-end parts inquiries"
  whyWorkWithUs={whyWorkWithUs}
  faq={faq}
  relatedPaths={relatedPaths}
/>
