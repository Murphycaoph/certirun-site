---
import PartInquiryPage from "../../../components/PartInquiryPage.astro";

const painPoints = [
  {
    title: "Same gearbox family, different spec",
    desc: "Clutch kits, discs, release bearings, and gearbox items can differ by size, spline, or transmission application.",
  },
  {
    title: "Wrong transmission scope breaks the order",
    desc: "Without clear application and spec details, suppliers may quote parts that fit the label but not the drivetrain setup.",
  },
  {
    title: "Mixed gearbox RFQs get fragmented",
    desc: "Discs, pressure plates, release items, and gearbox parts are often harder to compare when suppliers quote them separately.",
  },
];

const matchingInputs = [
  "OE number or part number",
  "Vehicle model or gearbox application",
  "Clutch size, spline details, or gearbox references",
  "Part photos",
  "Quantity list and destination",
];

const processSteps = [
  { title: "You send the details", desc: "Share the references you already have, including OE numbers, gearbox application, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical scope before quotation starts so drivetrain items stay aligned." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on fitment, quality level, and execution instead of price alone." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we continue with QC, packing checks, documents, and shipment coordination." },
];

const whyWorkWithUs = [
  {
    title: "We check fitment before quoting",
    desc: "These parts depend on clutch size, spline details, gearbox references, and vehicle application, so we confirm first.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same drivetrain setup and execution basis.",
  },
  {
    title: "We handle mixed drivetrain RFQs",
    desc: "We can organize clutch, release, and gearbox items into one workable sourcing flow.",
  },
];

const faq = [
  { q: "Can I start without OE numbers?", a: "Yes. Clutch size, spline details, gearbox references, or photos can also work." },
  { q: "Can you handle mixed gearbox and transmission parts in one order?", a: "Yes. We can organize multiple drivetrain items into one structured inquiry and shipment plan." },
  { q: "Do you support inspection before shipment?", a: "Yes. We follow up on QC, packing checks, and shipment coordination." },
];

const relatedPaths = [
  { title: "HOWO parts sourcing", desc: "For drivetrain RFQs tied to a specific truck platform.", href: "/product/brand/howo/" },
  { title: "Sinotruk parts sourcing", desc: "For platform-led gearbox and transmission demand.", href: "/product/brand/sinotruk/" },
  { title: "Engine parts", desc: "If the RFQ also includes overhaul items or engine-related spares.", href: "/product/part/engine-parts/" },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Gearbox And Transmission Parts Sourcing from China", description: "Send your gearbox and transmission parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certirun.com/product/part/clutch-and-transmission-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certirun.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certirun.com/product/" }, { "@type": "ListItem", position: 3, name: "Gearbox And Transmission Parts", item: "https://certirun.com/product/part/clutch-and-transmission-parts/" } ] },
];
---

<PartInquiryPage
  pageTitle="Send Your Gearbox And Transmission Parts Inquiry | Clear Matching and Workable Quotes"
  pageDescription="Send your gearbox and transmission parts inquiry with OE numbers, specs, photos, or part lists. CertiRun checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={["gearbox and transmission parts sourcing from China", "gearbox parts RFQ", "transmission parts supplier China", "drivetrain quote support", "gearbox and transmission inquiry"]}
  canonical="/product/part/clutch-and-transmission-parts/"
  ogImage="/images/kit/white background clutch and release parts flat lay, clutch disc, pressure plate, release bearing, pilot bearing, clutch fork, clean truck drivetrain catalog photo, no watermark, square composit.png"
  jsonLd={jsonLd}
  systemLabel="Gearbox and transmission parts"
  heroTitle="Send your gearbox and transmission parts inquiry and get clearer matching"
  heroLead="Send OE numbers, vehicle application, clutch size, spline details, gearbox references, photos, or your parts list. We review the scope first, then move into quotation, inspection, and shipment follow-up."
  primaryCtaLabel="Send Gearbox Inquiry"
  painPointsHeading="Running into these issues when sourcing gearbox and transmission parts?"
  painPoints={painPoints}
  matchingInputs={matchingInputs}
  processSteps={processSteps}
  whyWorkWithUsHeading="Why buyers use us for gearbox and transmission parts inquiries"
  whyWorkWithUs={whyWorkWithUs}
  faq={faq}
  relatedPaths={relatedPaths}
/>
