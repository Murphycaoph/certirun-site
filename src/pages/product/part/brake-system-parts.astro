---
import PartInquiryPage from "../../../components/PartInquiryPage.astro";

const painPoints = [
  {
    title: "Same part name, different fitment",
    desc: "Brake drums, chambers, linings, and valves can share a broad name but differ by size, type, or application.",
  },
  {
    title: "Cheap quotes can hide the wrong scope",
    desc: "Without clear dimensions, chamber type, valve spec, or lining material, suppliers may quote different products under one request.",
  },
  {
    title: "Mixed brake items get split too easily",
    desc: "Chambers, valves, drums, linings, and hardware often belong in one RFQ, but they become harder to review when quoted separately.",
  },
];

const matchingInputs = [
  "OE number or part number",
  "Vehicle model or VIN",
  "Key dimensions, chamber type, or valve spec",
  "Part photos",
  "Quantity list and destination",
];

const processSteps = [
  { title: "You send the details", desc: "Share the references you already have, including OE numbers, vehicle details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We confirm the scope before quotation starts so brake-side items are compared on the same basis." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on fitment, quality level, and execution instead of price alone." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we continue with QC, packing checks, documents, and shipment coordination." },
];

const whyWorkWithUs = [
  {
    title: "We check fitment before quoting",
    desc: "Brake parts depend on dimensions, chamber type, valve spec, lining material, and application, so we confirm first.",
  },
  {
    title: "We line up suppliers on the same scope",
    desc: "Quotes only help when they cover the same fitment, quality level, and packing basis.",
  },
  {
    title: "We handle mixed brake RFQs",
    desc: "We can organize chambers, linings, drums, valves, and service items into one workable sourcing flow.",
  },
];

const faq = [
  { q: "Can I start without OE numbers?", a: "Yes. Vehicle model, chamber size, valve reference, dimensions, or photos can also work." },
  { q: "Can you handle mixed brake items in one order?", a: "Yes. We can organize multiple brake lines into one RFQ and shipment plan." },
  { q: "Do you support inspection before shipment?", a: "Yes. We follow up on QC, packing checks, and shipment coordination." },
];

const relatedPaths = [
  { title: "HOWO parts sourcing", desc: "For inquiries tied to a specific truck platform.", href: "/product/brand/howo/" },
  { title: "Shacman parts sourcing", desc: "For platform-led brake RFQs tied to a known truck family.", href: "/product/brand/shacman/" },
  { title: "Air system parts", desc: "If the RFQ also includes valves, fittings, or other air-side items.", href: "/product/part/air-system-parts/" },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Brake System Parts Sourcing from China", description: "Send your brake system parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certirun.com/product/part/brake-system-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certirun.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certirun.com/product/" }, { "@type": "ListItem", position: 3, name: "Brake System Parts", item: "https://certirun.com/product/part/brake-system-parts/" } ] },
];
---

<PartInquiryPage
  pageTitle="Send Your Brake System Parts Inquiry | Clear Matching and Workable Quotes"
  pageDescription="Send your brake system parts inquiry with OE numbers, specs, photos, or part lists. CertiRun checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={["brake system parts sourcing from China", "brake system parts RFQ", "brake system parts supplier China", "brake parts quote support", "brake parts inquiry"]}
  canonical="/product/part/brake-system-parts/"
  ogImage="/images/Brake-System.png"
  jsonLd={jsonLd}
  systemLabel="Brake system parts"
  heroTitle="Send your brake system parts inquiry and get clearer matching"
  heroLead="Send OE numbers, dimensions, chamber type, valve references, photos, or your parts list. We review the scope first, then move into quotation, inspection, and shipment follow-up."
  primaryCtaLabel="Send Brake Inquiry"
  painPointsHeading="Running into these issues when sourcing brake system parts?"
  painPoints={painPoints}
  matchingInputs={matchingInputs}
  processSteps={processSteps}
  whyWorkWithUsHeading="Why buyers use us for brake system parts inquiries"
  whyWorkWithUs={whyWorkWithUs}
  faq={faq}
  relatedPaths={relatedPaths}
/>
