---
import PartInquiryPage from "../../../components/PartInquiryPage.astro";

const painPoints = [
  {
    title: "Same valve family, different spec",
    desc: "Small differences in thread size, port size, valve type, or pressure rating can make the quoted part unusable.",
  },
  {
    title: "Fast quotes often mix different standards",
    desc: "Without clear references, suppliers may quote fittings, valves, and chambers with different specs under one request.",
  },
  {
    title: "Air-side RFQs get split too early",
    desc: "Valves, air dryers, fittings, chambers, and repair kits often belong in one RFQ, but they are harder to compare when quoted separately.",
  },
];

const matchingInputs = [
  "OE number or part number",
  "Vehicle model or application",
  "Thread size, port size, valve type, or pressure spec",
  "Part photos",
  "Quantity list and destination",
];

const processSteps = [
  { title: "You send the details", desc: "Share the references you already have, including OE numbers, valve references, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical scope before quotation starts so air-side items stay aligned." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on spec, quality level, and execution instead of quoting blind." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we continue with QC, packing checks, documents, and shipment coordination." },
];

const whyWorkWithUs = [
  {
    title: "We check specs before quoting",
    desc: "Air-system parts depend on thread size, port size, valve type, pressure spec, and application, so we confirm first.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes are only useful when they match the same spec and execution basis.",
  },
  {
    title: "We handle mixed air-system RFQs",
    desc: "We can organize valves, fittings, air dryers, chambers, and repair items into one workable order.",
  },
];

const faq = [
  { q: "Can I start without OE numbers?", a: "Yes. Valve type, thread size, port size, pressure spec, or photos can also work." },
  { q: "Can you handle mixed air-system parts in one order?", a: "Yes. We can organize multiple air-side items into one structured inquiry and shipment plan." },
  { q: "Do you support inspection before shipment?", a: "Yes. We follow up on QC, packing checks, and shipment coordination." },
];

const relatedPaths = [
  { title: "HOWO parts sourcing", desc: "For platform-led RFQs tied to a known truck family.", href: "/product/brand/howo/" },
  { title: "MAN parts sourcing", desc: "For air-system demand tied to MAN vehicle applications.", href: "/product/brand/man/" },
  { title: "Brake system parts", desc: "If the RFQ also includes drums, linings, or brake-side service parts.", href: "/product/part/brake-system-parts/" },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Air System Parts Sourcing from China", description: "Send your air system parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certirun.com/product/part/air-system-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certirun.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certirun.com/product/" }, { "@type": "ListItem", position: 3, name: "Air System Parts", item: "https://certirun.com/product/part/air-system-parts/" } ] },
];
---

<PartInquiryPage
  pageTitle="Send Your Air System Parts Inquiry | Clear Matching and Workable Quotes"
  pageDescription="Send your air system parts inquiry with OE numbers, specs, photos, or part lists. CertiRun checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={["air system parts sourcing from China", "air system parts RFQ", "air system parts supplier China", "air system quote support", "air system parts inquiry"]}
  canonical="/product/part/air-system-parts/"
  ogImage="/images/hero-04-logistics-truck.webp"
  jsonLd={jsonLd}
  systemLabel="Air system parts"
  heroTitle="Send your air system parts inquiry and get clearer matching"
  heroLead="Send OE numbers, valve references, thread size, port size, pressure specs, photos, or your parts list. We review the scope first, then move into quotation, inspection, and shipment follow-up."
  primaryCtaLabel="Send Air System Inquiry"
  painPointsHeading="Running into these issues when sourcing air system parts?"
  painPoints={painPoints}
  matchingInputs={matchingInputs}
  processSteps={processSteps}
  whyWorkWithUsHeading="Why buyers use us for air system parts inquiries"
  whyWorkWithUs={whyWorkWithUs}
  faq={faq}
  relatedPaths={relatedPaths}
/>
