---
import BaseLayout from "../layouts/BaseLayout.astro";

const contactMethods = [
  { type: "Email", value: "murphy@certispares.com", href: "mailto:murphy@certispares.com" },
  { type: "WhatsApp", value: "+86 156 3302 2618", href: "https://wa.me/8615633022618" },
];
---

<BaseLayout
  title="Contact CertiRun"
  description="Contact CertiRun for structured sourcing, supplier verification, and delivery follow-up support."
  canonical="/contact/"
>
  <section class="subpageHero">
    <div class="container wide">
      <p class="eyebrow">CertiRun / Contact</p>
      <h1>Send your sourcing request or execution challenge.</h1>
      <p class="lead">
        Share the product scope, target quantity, current supplier status, and delivery
        market. CertiRun will help structure the next step.
      </p>
    </div>
  </section>

  <div class="pageShell">
    <section class="contactSection">
      <div class="container wide contactGrid">
        <div>
          <p class="pageBadge">Contact Methods</p>
          <h2>Reach CertiRun directly</h2>
          <p class="contactLead">
            For faster review, include photos, part numbers, drawings, target quantity,
            destination market, and any current supplier information.
          </p>
          <div class="methodGrid">
            {contactMethods.map((item) => (
              <a class="methodCard" href={item.href}>
                <span>{item.type}</span>
                <strong>{item.value}</strong>
              </a>
            ))}
          </div>
        </div>

        <form class="contactForm" action="/thank-you/" method="get">
          <div class="formHead">
            <p class="pageBadge">Inquiry Form</p>
            <h3>Request details</h3>
          </div>
          <label>
            <span>Name</span>
            <input name="name" type="text" autocomplete="name" placeholder="Your name" />
          </label>
          <label>
            <span>Email</span>
            <input name="email" type="email" autocomplete="email" placeholder="name@company.com" />
          </label>
          <label>
            <span>Message</span>
            <textarea name="message" rows="7" placeholder="Product scope, quantity, supplier status, and delivery market"></textarea>
          </label>
          <button class="submitButton" type="submit">Send Request</button>
        </form>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .contactSection{ padding:76px 0 78px; background:#fff; }
  .contactGrid{ display:grid; grid-template-columns:minmax(0,.85fr) minmax(0,1.15fr); gap:48px; align-items:start; }
  .pageBadge{
    display:inline-flex; align-items:center; justify-content:center; min-height:30px;
    padding:0 14px; margin:0 0 22px; border:1px solid rgba(10,37,64,.28);
    border-radius:8px; background:#F1F4F8; color:#0A2540;
    font-family:"Work Sans",Arial,sans-serif; font-size:.72rem; font-weight:800;
    line-height:1; letter-spacing:.16em; text-transform:uppercase;
  }
  .contactGrid h2{
    max-width:620px; font-size:clamp(2rem,3.2vw,3.45rem); line-height:1.1;
    letter-spacing:-.035em; font-weight:800;
  }
  .contactLead{ margin-top:18px; max-width:620px; color:var(--text-secondary); font-size:var(--type-body-lg); line-height:1.7; }
  .methodGrid{ display:grid; gap:16px; margin-top:34px; }
  .methodCard{
    display:grid; gap:8px; padding:24px; border:1px solid var(--border); border-radius:8px;
    background:#fff; box-shadow:0 8px 22px rgba(10,37,64,.04);
    transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease;
  }
  .methodCard:hover{ transform:translateY(-2px); border-color:rgba(10,37,64,.18); box-shadow:0 14px 32px rgba(10,37,64,.08); }
  .methodCard span{ color:var(--text-secondary); font-size:.78rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; }
  .methodCard strong{ color:var(--accent); font-size:1.18rem; }
  .contactForm{
    display:grid; gap:18px; padding:30px; border:1px solid var(--border); border-radius:8px;
    background:#F7F9FC; box-shadow:0 14px 34px rgba(10,37,64,.05);
  }
  .formHead h3{ font-size:1.35rem; font-weight:800; }
  .formHead .pageBadge{ margin-bottom:14px; }
  .contactForm label{ display:grid; gap:8px; }
  .contactForm label span{ color:var(--text-primary); font-weight:800; font-size:.9rem; }
  .submitButton{
    display:inline-flex; align-items:center; justify-content:center; min-height:58px; padding:0 28px;
    border:none; border-radius:8px; background:var(--accent); color:#fff; font:inherit; font-weight:800;
    cursor:pointer; box-shadow:0 12px 28px rgba(10,37,64,.18); transition:transform .16s ease, background-color .16s ease;
  }
  .submitButton:hover{ transform:translateY(-2px); background:var(--accent-hover); }
  @media (max-width:900px){
    .contactSection{ padding:56px 0; }
    .contactGrid{ grid-template-columns:1fr; }
    .contactForm{ padding:22px; }
  }
</style>
