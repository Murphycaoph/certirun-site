---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const brandEntries = [
  { label: "HOWO", href: "/product/brand/howo/", image: "/images/brands/howo.webp", alt: "HOWO logo" },
  { label: "Sinotruk", href: "/product/brand/sinotruk/", image: "/images/brands/sinotruk.png", alt: "Sinotruk logo" },
  { label: "Shacman", href: "/product/brand/shacman/", image: "/images/brands/shacman.png", alt: "Shacman logo" },
  { label: "Foton", href: "/product/brand/foton/", image: "/images/brands/foton.png", alt: "Foton logo" },
  { label: "Dongfeng", href: "/product/brand/dongfeng/", image: "/images/brands/dongfeng.png", alt: "Dongfeng logo" },
  { label: "FAW", href: "/product/brand/faw/", image: "/images/brands/faw.png", alt: "FAW logo" },
  { label: "JAC", href: "/product/brand/jac/", image: "/images/brands/jac.png", alt: "JAC logo" },
  { label: "Volvo Truck", href: "/product/brand/volvo-truck/", image: "/images/brands/volvo-truck.jpg", alt: "Volvo Truck visual" },
];

const partEntries = [
  { label: "Engine", href: "/product/part/engine-parts/", image: "/images/Engine-Parts.png", alt: "Engine parts" },
  { label: "Transmission", href: "/product/part/clutch-and-transmission-parts/", image: "/images/kit/white background clutch and release parts flat lay, clutch disc, pressure plate, release bearing, pilot bearing, clutch fork, clean truck drivetrain catalog photo, no watermark, square composit.png", alt: "Transmission parts" },
  { label: "Brake", href: "/product/part/brake-system-parts/", image: "/images/Brake-System.png", alt: "Brake system parts" },
  { label: "Suspension", href: "/product/part/suspension-parts/", image: "/images/Suspension.png", alt: "Suspension parts" },
  { label: "Electrical", href: "/product/", image: "/images/platform-library/electrical/electrical-candidate-1.png", alt: "Electrical parts" },
  { label: "Axle & Wheel End", href: "/product/part/axle-and-wheel-end-parts/", image: "/images/assemblies/assembly-axle.png", alt: "Axle and wheel end parts" },
];

const rawPosts = await getCollection("blog");
rawPosts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));

const insights = rawPosts.slice(0, 3).map((p) => ({
  title: p.data.title,
  tag: p.data.tag ?? "Insights",
  excerpt: p.data.excerpt ?? "",
  href: `/blog/${p.slug}`,
}));

const strategyCards = [
  {
    title: "Lower landed cost through consolidation",
    desc: "One container can combine multiple required products from multiple suppliers, helping buyers avoid shipping partially optimized orders and reducing the logistics cost carried by each SKU.",
    bullets: [
      "Multi-supplier loading into one container",
      "Better freight allocation across the order mix",
      "More commercial control than shipping each factory order separately",
    ],
    href: "/sourcing",
  },
  {
    title: "Faster turnover through balanced SKU sourcing",
    desc: "Instead of buying too deep into one product line just to fill a container, buyers can build a healthier stock mix across fast-moving and supporting items that fit real market demand.",
    bullets: [
      "Less pressure to overstock slow-moving SKUs",
      "Stronger inventory structure with the same budget",
      "Better cash-flow efficiency and repeat-order potential",
    ],
    href: "/sourcing",
  },
];

const whatWeDoCards = [
  {
    title: "Heavy duty truck parts",
    desc: "Heavy-duty truck parts remain the core RFQ category, supported by structured supplier comparison for B2B aftermarket buyers.",
  },
  {
    title: "Light-, medium-, and heavy-duty coverage",
    desc: "We handle RFQ sourcing across light-, medium-, and heavy-duty truck platforms for the commercial vehicle aftermarket.",
  },
  {
    title: "Brand-based RFQs",
    desc: "Common RFQs include Sinotruk HOWO, SHACMAN, Foton, Dongfeng, FAW, JAC, and OEM or part-number-based inquiries.",
  },
];

const popularQueries = [
  "heavy duty truck parts",
  "truck spare parts",
  "aftermarket truck parts",
  "Sinotruk HOWO parts",
  "Shacman parts",
  "Foton truck parts",
];

const whyChooseUsCards = [
  {
    title: "RFQ sourcing",
    desc: "Multiple supplier options with price, lead time, and sourcing risk comparison.",
    href: "/capabilities",
  },
  {
    title: "Quality control",
    desc: "Sampling, packaging verification, loading supervision, and photo or video checkpoints.",
    href: "/capabilities",
  },
  {
    title: "Consolidation and shipping",
    desc: "Consolidation planning, document control, and shipping coordination designed to lower landed cost and support a healthier inventory structure.",
    href: "/capabilities",
  },
];

const steps = [
  {
    number: "Step 1-2",
    title: "Share the RFQ",
    desc: "Share the RFQ, then receive supplier comparison across the right truck platform and part scope.",
    href: "/how-it-works",
  },
  {
    number: "Step 3-4",
    title: "Confirm and move into execution",
    desc: "Confirm the order with QC checkpoints, then move into consolidation, documents, and shipping with a focus on lower landed cost and better inventory balance.",
    href: "/how-it-works",
  },
];
---

<BaseLayout
  title="Wide Homepage Draft | CertiRun"
  description="Preview draft for a wider, more industrial homepage direction for CertiRun."
  robots="noindex,nofollow"
>
  <style>
    :root{
      --bg:#eef3f7;
      --text:#1d2a36;
      --muted:#5f6d86;
      --line:rgba(29,42,54,.10);
      --line-strong:rgba(29,42,54,.18);
      --brand:#3957E9;
      --brand2:#3957E9;
      --panel:#ffffff;
      --panel-soft:rgba(255,255,255,.72);
      --nav:#111F43;
      --hero-line:rgba(255,255,255,.14);
    }

    :global(main){
      background:
        linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
    }

    :global(.topbar){
      background:#111F43 !important;
      background-color:#111F43 !important;
      opacity:1 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important;
      box-shadow:none !important;
    }

    :global(.menu),
    :global(.menu a),
    :global(.menu a:hover){
      color:#fff;
    }

    :global(.menu a.active),
    :global(.drawerNav a.active){
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
      color:#fff;
    }

    :global(.cta){
      background:#3957E9;
      color:#fff;
    }

    :global(.footerWrap){
      border-top:1px solid rgba(255,255,255,.08);
      background:#0b1020;
    }

    :global(.container){
      max-width:1680px;
      padding:0 20px;
    }

    :global(.topbar .container){
      max-width:1680px !important;
      padding:0 20px !important;
    }

    .frame{
      width:min(100%, 1680px);
      margin:0 auto;
    }

    .section{
      padding:28px 0 0;
    }

    .sectionBlock{
      border:1px solid var(--line);
      background:var(--panel-soft);
      backdrop-filter: blur(8px);
    }

    .eyebrow{
      margin:0 0 12px;
      font-size:12px;
      font-weight:900;
      letter-spacing:.14em;
      text-transform:uppercase;
      color:rgba(234,240,255,.78);
    }

    .sectionEyebrow{
      margin:0 0 12px;
      font-size:12px;
      font-weight:900;
      letter-spacing:.14em;
      text-transform:uppercase;
      color:#4f6078;
    }

    .sectionTitle{
      margin:0;
      color:var(--text);
      font-size:36px;
      line-height:1.08;
      letter-spacing:-.03em;
    }

    .sectionLead{
      margin:14px 0 0;
      max-width:1120px;
      color:var(--muted);
      line-height:1.8;
    }

    .chipRow{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:6px;
    }

    .chip{
      padding:8px 12px;
      border:1px solid var(--line);
      background:#fff;
      color:#42546c;
      font-size:12px;
      font-weight:900;
      letter-spacing:.04em;
    }

    .more{
      color:#3957E9;
      font-weight:800;
      text-decoration:none;
    }

    .hero{
      position:relative;
      overflow:hidden;
      border-bottom:1px solid var(--line);
      background:#0b1020;
    }

    .hero::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(11,16,32,.40) 0%, rgba(11,16,32,.82) 66%, rgba(11,16,32,.96) 100%),
        radial-gradient(880px 420px at 18% 16%, rgba(57,87,233,.32), transparent 62%);
      z-index:1;
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      background:url("/images/hero-02-commercial-fleet.webp") center/cover no-repeat;
      opacity:.42;
      filter:saturate(.92) contrast(1.02);
    }

    .heroInner{
      position:relative;
      z-index:2;
      width:min(100%, 1680px);
      margin:0 auto;
      padding:52px 0 48px;
      display:grid;
      grid-template-columns:minmax(0, 1.34fr) minmax(460px, .9fr);
      gap:18px;
      align-items:stretch;
    }

    .heroCopy{
      border:1px solid var(--hero-line);
      background:linear-gradient(180deg, rgba(17,26,51,.64) 0%, rgba(17,26,51,.82) 100%);
      padding:34px 36px 28px;
    }

    .hero h1{
      margin:0;
      max-width:920px;
      color:#fff;
      font-size:58px;
      line-height:1;
      letter-spacing:-.05em;
    }

    .heroSub{
      margin:18px 0 0;
      max-width:860px;
      color:rgba(234,240,255,.86);
      line-height:1.78;
      font-size:18px;
    }

    .heroLines{
      margin:26px 0 0;
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:10px;
    }

    .heroLine{
      padding:14px 14px 14px 18px;
      border-left:3px solid rgba(57,87,233,.95);
      background:rgba(255,255,255,.04);
      color:rgba(255,255,255,.9);
      line-height:1.6;
      min-height:72px;
    }

    .heroActions{
      margin-top:28px;
      display:flex;
      gap:12px;
      flex-wrap:wrap;
    }

    .heroBtn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:48px;
      padding:0 18px;
      border:1px solid rgba(255,255,255,.14);
      color:#fff;
      background:rgba(255,255,255,.04);
      font-weight:800;
      letter-spacing:.01em;
    }

    .heroBtn.primary{
      background:#3957E9;
      border-color:#3957E9;
    }

    .heroPanel{
      display:grid;
      grid-template-rows:1.2fr auto;
      gap:0;
      border:1px solid var(--hero-line);
      background:rgba(17,26,51,.76);
      min-height:100%;
    }

    .panelImage{
      position:relative;
      min-height:340px;
      overflow:hidden;
      border-bottom:1px solid var(--hero-line);
    }

    .panelImage img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .panelImage::after{
      content:"";
      position:absolute;
      inset:auto 0 0 0;
      height:50%;
      background:linear-gradient(180deg, transparent, rgba(11,16,32,.78));
    }

    .panelMeta{
      display:grid;
      grid-template-columns:repeat(3, 1fr);
    }

    .metaCell{
      padding:18px 16px;
      border-right:1px solid var(--hero-line);
    }

    .metaCell:last-child{
      border-right:0;
    }

    .metaLabel{
      font-size:11px;
      font-weight:900;
      letter-spacing:.12em;
      text-transform:uppercase;
      color:rgba(234,240,255,.56);
    }

    .metaValue{
      margin-top:10px;
      color:#fff;
      line-height:1.55;
      font-weight:700;
    }

    .entryShell{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:14px;
      margin-top:22px;
    }

    .entryPanel{
      border:1px solid var(--line-strong);
      background:linear-gradient(180deg, rgba(255,255,255,.82) 0%, rgba(255,255,255,.68) 100%);
      padding:22px;
    }

    .entryHead{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-end;
      border-bottom:1px solid var(--line);
      padding-bottom:16px;
      margin-bottom:18px;
    }

    .entryTitle{
      margin:0;
      color:var(--text);
      font-size:26px;
      letter-spacing:-.02em;
    }

    .entryHint{
      margin:8px 0 0;
      color:var(--muted);
      line-height:1.7;
    }

    .entryBadge{
      padding:8px 12px;
      border:1px solid var(--line);
      background:#fff;
      color:#42546c;
      font-size:12px;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.08em;
      white-space:nowrap;
    }

    .entryGrid{
      position:relative;
      overflow:hidden;
      padding:4px 0;
    }

    .entryTrack{
      display:flex;
      gap:10px;
      width:max-content;
      animation: marquee 28s linear infinite;
    }

    .entryPanel:last-child .entryTrack{
      animation-duration: 30s;
    }

    .entryGrid:hover .entryTrack{
      animation-play-state: paused;
    }

    .entryCard{
      display:flex;
      flex:0 0 190px;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      min-height:148px;
      padding:14px 16px;
      border:1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(255,255,255,.14) 0%, rgba(17,26,51,.02) 100%),
        #fff;
      position:relative;
      overflow:hidden;
      transition:transform .16s ease, border-color .16s ease, background .16s ease;
    }

    .entryCard::before{
      content:"";
      position:absolute;
      inset:0 auto auto 0;
      width:54px;
      height:54px;
      border-top:3px solid rgba(57,87,233,.72);
      border-left:3px solid rgba(57,87,233,.72);
      opacity:.56;
    }

    .entryCard:hover{
      transform:translateY(-2px);
      border-color:rgba(57,87,233,.34);
      background:#fdfefe;
    }

    .entryCard span{
      position:relative;
      z-index:1;
      color:var(--text);
      font-size:18px;
      font-weight:850;
      line-height:1.2;
    }

    .entryMedia{
      position:relative;
      z-index:1;
      height:96px;
      width:100%;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .entryMedia img{
      max-width:100%;
      max-height:100%;
      object-fit:contain;
      display:block;
    }

    .strategyGrid{
      margin-top:22px;
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:14px;
    }

    .strategyCard{
      border:1px solid var(--line);
      background:#fff;
      padding:22px;
      min-height:290px;
      position:relative;
      display:flex;
      flex-direction:column;
    }

    .strategyCard::before{
      content:"";
      display:block;
      width:34px;
      height:4px;
      background:#3957E9;
      margin-bottom:18px;
    }

    .strategyCard h3{
      margin:0;
      color:var(--text);
      font-size:22px;
      letter-spacing:-.02em;
    }

    .strategyCard p{
      margin:12px 0 0;
      color:var(--muted);
      line-height:1.8;
    }

    .strategyList{
      margin:18px 0 0;
      padding:0;
      list-style:none;
      display:grid;
      gap:10px;
      color:var(--text);
    }

    .strategyList li{
      display:grid;
      grid-template-columns:12px 1fr;
      gap:10px;
      align-items:start;
      line-height:1.7;
    }

    .strategyList li::before{
      content:"";
      width:8px;
      height:8px;
      background:#3957E9;
      margin-top:9px;
    }

    .whatGrid{
      margin-top:22px;
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:14px;
    }

    .whatCard{
      border:1px solid var(--line);
      background:#fff;
      padding:22px;
      min-height:220px;
    }

    .whatIndex{
      font-size:44px;
      line-height:1;
      color:#d2daf6;
      font-weight:900;
      letter-spacing:-.06em;
    }

    .whatCard h3{
      margin:14px 0 0;
      color:var(--text);
      font-size:22px;
      letter-spacing:-.02em;
    }

    .whatCard p{
      margin:12px 0 0;
      color:var(--muted);
      line-height:1.8;
    }

    .flowWrap{
      margin-top:20px;
      display:grid;
      grid-template-columns:repeat(5, minmax(0, 1fr));
      gap:0;
      border:1px solid var(--line-strong);
      background:#fff;
    }

    .step{
      padding:18px 16px 18px;
      border-right:1px solid var(--line);
      position:relative;
      min-height:172px;
    }

    .step:last-child{
      border-right:0;
    }

    .step::after{
      content:"";
      position:absolute;
      right:-1px;
      top:24px;
      width:12px;
      height:12px;
      background:#3957E9;
      transform:translateX(50%) rotate(45deg);
      z-index:2;
    }

    .step:last-child::after{
      display:none;
    }

    .stepNumber{
      font-size:46px;
      line-height:1;
      color:#d2daf6;
      font-weight:900;
      letter-spacing:-.06em;
    }

    .stepTitle{
      margin:16px 0 0;
      color:var(--text);
      font-size:20px;
      font-weight:850;
      letter-spacing:-.02em;
    }

    .stepDesc{
      margin:10px 0 0;
      color:var(--muted);
      line-height:1.75;
    }

    .trustGrid{
      margin-top:22px;
      display:grid;
      grid-template-columns:minmax(0, .9fr) minmax(0, 1.1fr);
      gap:14px;
    }

    .trustText{
      border:1px solid var(--line);
      background:#fff;
      padding:26px;
    }

    .trustList{
      display:grid;
      gap:0;
      margin-top:18px;
      border-top:1px solid var(--line);
    }

    .trustItem{
      display:grid;
      grid-template-columns:32px 1fr;
      gap:14px;
      padding:16px 0;
      border-bottom:1px solid var(--line);
      color:var(--text);
      line-height:1.75;
    }

    .trustMark{
      width:32px;
      height:32px;
      display:grid;
      place-items:center;
      background:#111F43;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .trustStats{
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:12px;
    }

    .statCard{
      border:1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(17,31,67,.98) 0%, rgba(17,26,51,.94) 100%);
      color:#fff;
      padding:22px;
      min-height:164px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .statValue{
      font-size:26px;
      line-height:1.15;
      letter-spacing:-.03em;
      font-weight:900;
    }

    .statLabel{
      margin-top:18px;
      color:rgba(234,240,255,.82);
      line-height:1.7;
    }

    .proofGrid{
      margin-top:22px;
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:12px;
    }

    .proofCard{
      border:1px solid var(--line);
      background:#fff;
      min-height:196px;
      padding:18px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .proofIndex{
      width:max-content;
      padding:6px 9px;
      border:1px solid var(--line);
      color:#3957E9;
      font-size:12px;
      font-weight:900;
      letter-spacing:.12em;
      text-transform:uppercase;
    }

    .proofCard h3{
      margin:22px 0 0;
      color:var(--text);
      font-size:20px;
      letter-spacing:-.02em;
    }

    .proofCard p{
      margin:10px 0 0;
      color:var(--muted);
      line-height:1.75;
    }

    .insightGrid{
      margin-top:22px;
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:12px;
    }

    .insightCard{
      border:1px solid var(--line);
      background:#fff;
      padding:18px;
      min-height:220px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .insightTag{
      display:inline-flex;
      width:max-content;
      padding:6px 9px;
      border:1px solid var(--line);
      color:#3957E9;
      font-size:12px;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
    }

    .insightCard h3{
      margin:18px 0 0;
      color:var(--text);
      font-size:22px;
      line-height:1.3;
      letter-spacing:-.02em;
    }

    .insightCard p{
      margin:12px 0 0;
      color:var(--muted);
      line-height:1.75;
    }

    .ctaBand{
      margin:34px 0 0;
      border:1px solid rgba(255,255,255,.10);
      background:
        linear-gradient(135deg, rgba(17,31,67,.98) 0%, rgba(17,26,51,.94) 68%, rgba(57,87,233,.88) 100%);
      color:#fff;
      overflow:hidden;
    }

    .ctaInner{
      display:grid;
      grid-template-columns:minmax(0, 1fr);
      gap:22px;
      align-items:start;
      padding:26px 28px;
    }

    .ctaTitle{
      margin:0;
      font-size:34px;
      line-height:1.08;
      letter-spacing:-.04em;
    }

    .ctaText{
      margin:12px 0 0;
      color:rgba(234,240,255,.82);
      line-height:1.75;
      max-width:720px;
    }

    .ctaActions{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      justify-content:flex-start;
    }

    .ctaAction{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:48px;
      padding:0 18px;
      border:1px solid rgba(255,255,255,.16);
      color:#fff;
      background:rgba(255,255,255,.06);
      font-weight:800;
      white-space:nowrap;
    }

    .ctaAction.primary{
      background:#3957E9;
      border-color:#3957E9;
    }

    @keyframes marquee{
      from{
        transform:translateX(0);
      }
      to{
        transform:translateX(-50%);
      }
    }

    @media (min-width: 1600px){
      :global(.container){
        max-width:1760px;
        padding:0 18px;
      }

      :global(.topbar .container){
        max-width:1760px !important;
        padding:0 18px !important;
      }

      .frame,
      .heroInner{
        width:min(100%, 1760px);
      }

      .heroInner{
        grid-template-columns:minmax(0, 1.42fr) minmax(520px, .92fr);
      }
    }

    @media (max-width: 1180px){
      .heroInner,
      .trustGrid,
      .ctaInner{
        grid-template-columns:1fr;
      }

      .heroLines,
      .proofGrid{
        grid-template-columns:repeat(2, minmax(0, 1fr));
      }

      .insightGrid{
        grid-template-columns:repeat(2, minmax(0, 1fr));
      }

      .entryGrid{
        overflow:hidden;
      }

      .strategyGrid,
      .whatGrid{
        grid-template-columns:1fr;
      }

      .trustStats{
        grid-template-columns:repeat(3, minmax(0, 1fr));
      }

      .flowWrap{
        grid-template-columns:1fr;
      }

      .step{
        border-right:0;
        border-bottom:1px solid var(--line);
        min-height:auto;
      }

      .step:last-child{
        border-bottom:0;
      }

      .step::after{
        top:auto;
        right:auto;
        left:24px;
        bottom:-1px;
      }
    }

    @media (max-width: 980px){
      :global(.container){
        padding:0 16px;
      }

      :global(.topbar .container){
        padding:0 16px !important;
      }

      .frame,
      .heroInner{
        width:100%;
      }

      .hero h1{
        font-size:42px;
      }

      .heroCopy{
        padding:24px 22px 22px;
      }

      .entryShell,
      .strategyGrid,
      .whatGrid{
        grid-template-columns:1fr;
      }

      .heroLines{
        grid-template-columns:1fr;
      }

      .entryCard{
        flex-basis:160px;
        min-height:128px;
      }

      .entryMedia{
        height:78px;
      }

      .trustStats{
        grid-template-columns:1fr;
      }

      .panelMeta{
        grid-template-columns:1fr;
      }

      .metaCell{
        border-right:0;
        border-bottom:1px solid var(--hero-line);
      }

      .metaCell:last-child{
        border-bottom:0;
      }

      .proofGrid{
        grid-template-columns:1fr;
      }

      .insightGrid{
        grid-template-columns:1fr;
      }

      .ctaActions{
        justify-content:flex-start;
      }

      .ctaTitle,
      .sectionTitle{
        font-size:28px;
      }
    }
  </style>

  <header class="hero">
