        <div class="panelMeta">
          <div class="metaCell">
            <div class="metaLabel">Cost</div>
            <div class="metaValue">Multi-supplier consolidation to lower landed cost per order.</div>
          </div>
          <div class="metaCell">
            <div class="metaLabel">Mix</div>
            <div class="metaValue">Balanced multi-SKU sourcing aligned with real replenishment demand.</div>
          </div>
          <div class="metaCell">
            <div class="metaLabel">Control</div>
