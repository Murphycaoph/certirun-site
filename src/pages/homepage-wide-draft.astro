                </p>
              </div>
              <div class="entryBadge">Platform Entry</div>
            </div>
            <div class="entryGrid">
              <div class="entryTrack">
                {[...brandEntries, ...brandEntries].map((item, index) => (
                  <a class="entryCard" href={item.href} aria-label={item.label} aria-hidden={index >= brandEntries.length ? "true" : "false"}>
                    <div class="entryMedia">
                      <img src={item.image} alt={item.alt} loading="lazy" decoding="async" />
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>

          <section class="entryPanel" id="part-entry">
            <div class="entryHead">
              <div>
                <h3 class="entryTitle">Browse by Part System</h3>
                <p class="entryHint">
                  Use system-led entry when the inquiry starts from the category itself or a mixed replenishment scope.
                </p>
              </div>
              <div class="entryBadge">System Entry</div>
            </div>
            <div class="entryGrid">
              <div class="entryTrack">
                {[...partEntries, ...partEntries].map((item, index) => (
                  <a class="entryCard" href={item.href} aria-label={item.label} aria-hidden={index >= partEntries.length ? "true" : "false"}>
                    <div class="entryMedia">
